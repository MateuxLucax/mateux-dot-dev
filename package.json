	"license": "GPL-3.0-only",
	"homepage": "https://mateux.dev",
	"displayName": "mateux.dev",
	"version": "3.1.0",
	"type": "module",
	"description": "This is a SvelteKit application with Tailwind CSS. It is designed to be a simple and efficient profile page with link to my web profiles.",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/enhanced-img": "^0.9.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"mdsvex": "^0.12.7",
		"mermaid": "^11.13.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shiki": "^3.23.0",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.2"
	},
	"overrides": {
		"rollup": ">=4.59.0",
		"flatted": ">=3.4.2",
		"lodash-es": "^4.18.1"
	}
}
